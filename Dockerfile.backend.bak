# syntax=docker/dockerfile:1

FROM golang:1.25-bookworm AS builder

ENV GOPROXY=https://goproxy.cn,https://goproxy.io,direct
ENV GOSUMDB=off

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .

RUN CGO_ENABLED=0 GOOS=linux go build -o /app/aegis-waf ./cmd/aegis-waf/main.go

FROM alpine:3.19 AS runtime

RUN apk --no-cache add ca-certificates

# 创建挂载所需的目录
RUN mkdir -p /app/data /app/rules /app/configs

COPY --from=builder /app/aegis-waf /app/aegis-waf

WORKDIR /app

EXPOSE 8088

CMD ["/app/aegis-waf"]
RUN mkdir -p /app/data
